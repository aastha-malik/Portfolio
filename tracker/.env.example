# Copy to tracker/.env for local dev:  cp .env.example .env
# (.env is gitignored by the portfolio repo. On Render, set these in the
#  service's Environment tab instead.)

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (secret, bypasses RLS). Never ship this to the browser.
SUPABASE_SERVICE_KEY=your-service-role-key

# Long random string. Same value goes in the GitHub Actions secret SUMMARY_TOKEN.
#   generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SUMMARY_TOKEN=change-me-to-a-long-random-string

# Browser origins allowed to call /track (comma-separated, no trailing slash).
ALLOWED_ORIGINS=https://aastha-malik-portfolio.onrender.com,http://localhost:3000
